# ============================================================
# .env.example — copy this to .env and fill in your values
#
# BEGINNER STEPS:
# 1. Go to Firebase Console → Project Settings → Service Accounts
# 2. Click "Generate new private key" → downloads a .json file
# 3. Open that file and copy the values below
#
# IMPORTANT: Never commit .env to git. It is in .gitignore.
# On Render.com you paste these values into their dashboard
# under Environment Variables — NOT in a file.
# ============================================================

# From your Firebase service account JSON file:
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Port for local development (Render sets this automatically in production)
PORT=3000

# Your Firebase web app config (same values as in firebase.service.js)
# These are safe to expose — they are protected by Firestore security rules
FIREBASE_API_KEY=your-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
